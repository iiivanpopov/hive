{
  "name": "hive",
  "type": "module",
  "workspaces": {
    "packages": ["backend", "frontend"],
    "catalog": {
      "@antfu/eslint-config": "^8.0.0",
      "@types/bun": "^1.3.11",
      "@typescript/native-preview": "^7.0.0-dev.20260405.1",
      "eslint": "^9.39.4",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "dev": "bun --workspaces dev",
    "prod": "bun --workspaces prod",
    "build:dev": "bun --workspaces build:dev",
    "build:prod": "bun --workspaces build:prod",
    "lint": "bun --workspaces lint",
    "lint:css": "bun --filter hive-frontend lint:css",
    "db:generate": "bun --filter hive-backend db:generate",
    "db:push": "bun --filter hive-backend db:push",
    "db:studio": "bun --filter hive-backend db:studio",
    "test:unit": "bun --filter hive-backend test:unit",
    "test:it": "bun --filter hive-backend test:it",
    "test:backend": "cd backend && bun run test",
    "test:frontend": "cd frontend && bun run test",
    "test": "bun test:backend && bun test:frontend",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "eslint": "catalog:",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": ["sh -c 'bun --filter hive-backend lint --fix && bun --filter hive-frontend lint --fix'"],
    "*.css": ["bun --filter \"./frontend\" lint:css --fix"]
  }
}
